# BrandForge AI Environment Variables Template

# 1. Groq API Key (Recommended for ultra-fast response)
# Get a free key here: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# 2. Google Gemini API Key (Alternative)
# Get a free key here: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Backend configuration
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
